APP_NAME=adaptive-hybrid-rag
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ROOT_DIR=.

RAG_DATA_DIR=data
RAG_DOCUMENTS_DIR=data/documents
RAG_SQLITE_PATH=data/rag_metadata.sqlite3
RAG_CHROMA_PATH=data/chroma
RAG_CHROMA_COLLECTION=paper_chunks

RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RAG_RERANKER_MODEL=BAAI/bge-reranker-base
RAG_CHUNK_CHARS=600
RAG_CHUNK_OVERLAP=80
RAG_BASE_K=12
RAG_MAX_K=30
RAG_RRF_K=60
RAG_MAX_RETRIES=3
RAG_ENABLE_PDFPLUMBER=true

# --- OpenRouter (recommended) ---
LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Add multiple keys separated by commas for automatic rotation on rate limits
OPENROUTER_API_KEYS=sk-or-v1-your-key-here

# --- Gemini direct (set LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (set LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_RESPONSES_MODEL=gpt-4o-mini

REQUEST_TIMEOUT_SECONDS=45
