APP_NAME=adaptive-hybrid-rag
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ROOT_DIR=.

RAG_DATA_DIR=data
RAG_DOCUMENTS_DIR=data/documents
RAG_SQLITE_PATH=data/rag_metadata.sqlite3
RAG_CHROMA_PATH=data/chroma
RAG_CHROMA_COLLECTION=paper_chunks

RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RAG_RERANKER_MODEL=BAAI/bge-reranker-base
RAG_CHUNK_CHARS=200
RAG_CHUNK_OVERLAP=40
RAG_BASE_K=10
RAG_MAX_K=30
RAG_RRF_K=60
RAG_MAX_RETRIES=3
RAG_ENABLE_PDFPLUMBER=true

LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_RESPONSES_MODEL=gpt-5-mini

# Gemini (set LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

REQUEST_TIMEOUT_SECONDS=45
